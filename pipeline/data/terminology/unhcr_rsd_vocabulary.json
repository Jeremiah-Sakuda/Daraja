    "common_interview_phrases": [
      {"en": "Please tell me about yourself", "so": "Fadlan ii sheeg wax ku saabsan naftaada", "sw": "Tafadhali niambie kuhusu wewe"},
      {"en": "Why did you leave your country?", "so": "Maxaad uga tagay dalkaagii?", "sw": "Kwa nini uliondoka nchi yako?"},
      {"en": "When did you leave?", "so": "Goorma ayaad tagtay?", "sw": "Uliondoka lini?"},
      {"en": "How did you travel?", "so": "Sidee ayaad u safartay?", "sw": "Ulisafiria vipi?"},
      {"en": "What happened to you?", "so": "Maxaa kugu dhacay?", "sw": "Nini kilikupata?"},
      {"en": "Were you harmed?", "so": "Miyaa laguu dhaawacay?", "sw": "Je, ulidhuru?"},
      {"en": "Do you have any documents?", "so": "Ma haysataa warqado?", "sw": "Je, una hati zozote?"},
      {"en": "Where is your family?", "so": "Xaggee bay joogaan qoyskaaga?", "sw": "Familia yako iko wapi?"},
      {"en": "Can you return to your country?", "so": "Ma ku noqon kartaa dalkaagii?", "sw": "Je, unaweza kurudi nchi yako?"},
      {"en": "Do you need an interpreter?", "so": "Ma u baahan tahay turjumaan?", "sw": "Je, unahitaji mkalimani?"},
      {"en": "Is there anything else you want to tell me?", "so": "Ma jiraa wax kale oo aad rabto inaad ii sheegto?", "sw": "Je, kuna kitu kingine unachotaka kuniambia?"}
